#!/usr/bin/env bash
# ──────────────────────────────────────────────────────────────────────
# mcplab — CLI for MCP Lab: test, profile, and audit MCP servers
# ──────────────────────────────────────────────────────────────────────
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ── Colors & Symbols ─────────────────────────────────────────────────
if [[ -t 1 ]]; then
    BOLD="\033[1m"
    DIM="\033[2m"
    RESET="\033[0m"
    RED="\033[31m"
    GREEN="\033[32m"
    YELLOW="\033[33m"
    BLUE="\033[34m"
    MAGENTA="\033[35m"
    CYAN="\033[36m"
    WHITE="\033[37m"
    BG_BLACK="\033[40m"
    PASS="${GREEN}PASS${RESET}"
    FAIL="${RED}FAIL${RESET}"
    WARN="${YELLOW}WARN${RESET}"
    INFO="${CYAN}INFO${RESET}"
    DOT="${DIM}·${RESET}"
    ARROW="${DIM}→${RESET}"
    CHECK="${GREEN}✓${RESET}"
    CROSS="${RED}✗${RESET}"
    BULLET="${DIM}▸${RESET}"
else
    BOLD="" DIM="" RESET=""
    RED="" GREEN="" YELLOW="" BLUE="" MAGENTA="" CYAN="" WHITE="" BG_BLACK=""
    PASS="PASS" FAIL="FAIL" WARN="WARN" INFO="INFO"
    DOT="." ARROW="->" CHECK="+" CROSS="x" BULLET=">"
fi

# ── Banner ────────────────────────────────────────────────────────────
show_banner() {
    echo -e ""
    echo -e "  ${BOLD}${CYAN}╔╦╗╔═╗╔═╗  ╦  ╔═╗╔╗ ${RESET}"
    echo -e "  ${BOLD}${CYAN}║║║║  ╠═╝  ║  ╠═╣╠╩╗${RESET}"
    echo -e "  ${BOLD}${CYAN}╩ ╩╚═╝╩    ╩═╝╩ ╩╚═╝${RESET}"
    echo -e "  ${DIM}MCP Server Test Harness${RESET}  ${DIM}v0.1.0${RESET}"
    echo -e ""
}

# ── Help ──────────────────────────────────────────────────────────────
show_help() {
    show_banner
    echo -e "  ${BOLD}Usage:${RESET}  mcplab ${CYAN}<command>${RESET} [options]"
    echo -e ""
    echo -e "  ${BOLD}Commands:${RESET}"
    echo -e "    ${CYAN}profile${RESET}  ${DIM}<server-cmd>${RESET}    Profile a real MCP server (conformance + latency + security)"
    echo -e "    ${CYAN}test${RESET}     ${DIM}[suite]${RESET}         Run test suites against the mock harness"
    echo -e "    ${CYAN}record${RESET}   ${DIM}<server-cmd>${RESET}    Record MCP traffic to a JSONL file"
    echo -e "    ${CYAN}report${RESET}   ${DIM}<json-file>${RESET}     Render a JSON report as a formatted terminal report"
    echo -e "    ${CYAN}tools${RESET}    ${DIM}<server-cmd>${RESET}    List all tools exposed by an MCP server"
    echo -e "    ${CYAN}help${RESET}                     Show this help"
    echo -e ""
    echo -e "  ${BOLD}Test Suites:${RESET}"
    echo -e "    ${DIM}all${RESET}          Run everything                  ${DIM}mcplab test${RESET}"
    echo -e "    ${DIM}conformance${RESET}  JSON-RPC / MCP spec compliance  ${DIM}mcplab test conformance${RESET}"
    echo -e "    ${DIM}security${RESET}     Trust boundaries & injection    ${DIM}mcplab test security${RESET}"
    echo -e "    ${DIM}transport${RESET}    Latency & error resilience      ${DIM}mcplab test transport${RESET}"
    echo -e "    ${DIM}evaluation${RESET}   Context window token costs      ${DIM}mcplab test evaluation${RESET}"
    echo -e "    ${DIM}integration${RESET}  Multi-server & sessions         ${DIM}mcplab test integration${RESET}"
    echo -e "    ${DIM}fuzz${RESET}         Property-based fuzzing          ${DIM}mcplab test fuzz${RESET}"
    echo -e ""
    echo -e "  ${BOLD}Examples:${RESET}"
    echo -e "    ${DIM}# Profile the official filesystem server${RESET}"
    echo -e "    mcplab profile \"npx -y @modelcontextprotocol/server-filesystem /tmp\""
    echo -e ""
    echo -e "    ${DIM}# List tools from a server${RESET}"
    echo -e "    mcplab tools \"npx -y @modelcontextprotocol/server-memory\""
    echo -e ""
    echo -e "    ${DIM}# Run only security tests${RESET}"
    echo -e "    mcplab test security"
    echo -e ""
    echo -e "    ${DIM}# Record traffic for analysis${RESET}"
    echo -e "    mcplab record \"python my_server.py\" -o traffic.jsonl"
