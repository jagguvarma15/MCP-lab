#!/usr/bin/env bash
# ──────────────────────────────────────────────────────────────────────
# mcplab — activates the .venv and launches the CLI
# ──────────────────────────────────────────────────────────────────────
set -euo pipefail

DIR="$(cd "$(dirname "$0")" && pwd)"

if [ ! -d "$DIR/.venv" ]; then
    echo "  error: .venv not found. Run 'make install' first."
    exit 1
fi

source "$DIR/.venv/bin/activate"
exec python -m harness.cli "$@"
