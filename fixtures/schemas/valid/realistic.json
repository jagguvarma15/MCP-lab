{
  "name": "search_documents",
  "description": "Search through the document repository using full-text search. Returns matching documents with relevance scores.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "description": "Full-text search query"
      },
      "max_results": {
        "type": "integer",
        "description": "Maximum number of results to return (1-100)"
      },
      "filters": {
        "type": "object",
        "description": "Optional filters to narrow results",
        "properties": {
          "date_from": {
            "type": "string",
            "description": "Start date in ISO 8601 format"
          },
          "date_to": {
            "type": "string",
            "description": "End date in ISO 8601 format"
          },
          "doc_type": {
            "type": "string",
            "description": "Filter by document type",
            "enum": ["pdf", "docx", "txt", "markdown", "html"]
          },
          "author": {
            "type": "string",
            "description": "Filter by author name or email"
          }
        }
      },
      "sort_by": {
        "type": "string",
        "description": "Sort order for results",
        "enum": ["relevance", "date_asc", "date_desc", "title"]
      },
      "include_snippets": {
        "type": "boolean",
        "description": "Whether to include text snippets around matches"
      }
    },
    "required": ["query"]
  }
}
